---
import ProjectCard from './ProjectCard.astro';

const projects = [
  {
    num: '01',
    title: 'Scroll-Driven Section Timeline',
    description:
      'Scroll-pinned GSAP timeline with SplitText word reveals, clip-path image sequences, and SVG opacity choreography across multiple panels.',
    tags: ['GSAP', 'SplitText', 'ScrollTrigger', 'Webflow'],
    gradient: 'linear-gradient(135deg, #E84B2A 0%, #FF7A5A 100%)',
    initials: 'ST',
    label: 'Scroll Timeline',
  },
  {
    num: '02',
    title: 'Gear UI & SVG Race Map',
    description:
      'Rotating gear tab switcher combined with a DrawSVG race map — a moving car follows the path with IntersectionObserver-gated entry and hard reset on tab switch.',
    tags: ['DrawSVG', 'MotionPath', 'GSAP', 'Custom JS'],
    gradient: 'linear-gradient(135deg, #F97316 0%, #FBBF24 100%)',
    initials: 'GR',
    label: 'Gear & Race Map',
  },
  {
    num: '03',
    title: 'Hotel CMS — Property Listings',
    description:
      'Dynamic Webflow CMS page rendering hotel amenities from malformed JSON — parsed, sanitised, and displayed without breaking the editor experience.',
    tags: ['Webflow CMS', 'JSON', 'JavaScript'],
    gradient: 'linear-gradient(135deg, #E84B2A 0%, #F97316 100%)',
    initials: 'HC',
    label: 'Hotel CMS',
  },
  {
    num: '04',
    title: 'Analytics Audit & Full Fix',
    description:
      'Diagnosed and corrected a broken tracking stack — misplaced Pipedrive script, GA4 opt-out blocking all events, misconfigured Meta Pixel, and wrong GTM noscript placement.',
    tags: ['GA4', 'GTM', 'Meta Pixel', 'Pipedrive'],
    gradient: 'linear-gradient(135deg, #111 0%, #444 100%)',
    initials: 'AA',
    label: 'Analytics Audit',
  },
  {
    num: '05',
    title: 'Counter Animation System',
    description:
      'Reusable scroll-triggered count-up script supporting multiple wrapper classes, suffix spacing, and IntersectionObserver entry — works across any Webflow site.',
    tags: ['JavaScript', 'IntersectionObserver', 'Webflow'],
    gradient: 'linear-gradient(135deg, #F97316 0%, #E84B2A 100%)',
    initials: 'CA',
    label: 'Counter Animation',
  },
  {
    num: '06',
    title: 'Scroll Nav Behaviour',
    description:
      'GSAP ScrollTrigger-based nav that hides on scroll down, reappears on scroll up — mobile-conditional thresholds and class toggling for style states.',
    tags: ['GSAP', 'ScrollTrigger', 'Mobile', 'Webflow'],
    gradient: 'linear-gradient(135deg, #C93D20 0%, #E84B2A 100%)',
    initials: 'NB',
    label: 'Nav Behaviour',
  },
];
---

<section class="projects" id="work">
  <div class="container">
    <div class="section-label">
      <span>Selected Work</span>
    </div>
    <div class="projects-grid">
      {projects.map((p) => <ProjectCard {...p} />)}
    </div>
  </div>
</section>

<style>
  .projects {
    padding: 72px 0 80px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 28px;
  }

  @media (max-width: 640px) {
    .projects {
      padding: 48px 0 56px;
    }

    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>