<style>
  .hero {
    border-bottom: 1px solid var(--border);
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-top: 80px;
    padding-bottom: 80px;
    gap: 0;
  }

  .hero-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    overflow: hidden;
    margin-bottom: 24px;
    border: 2px solid var(--border);
  }

  .hero-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  .hero-greeting {
    font-size: 15px;
    color: var(--muted);
    margin-bottom: 20px;
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(36px, 6vw, 68px);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin-bottom: 24px;
    max-width: 700px;
  }

  .hero-desc {
    font-size: 15px;
    color: #666;
    line-height: 1.75;
    max-width: 420px;
    margin-bottom: 36px;
  }

  .hero-desc strong {
    color: var(--ink);
    font-weight: 600;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--ink);
    color: #fff;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 14px 28px;
    border-radius: 100px;
    transition: background 0.2s;
    margin-bottom: 40px;
  }

  .hero-cta:hover {
    background: var(--red);
  }

  .hero-socials {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .hero-socials a {
    font-size: 20px;
    color: var(--muted);
    transition: color 0.2s;
  }

  .hero-socials a:hover {
    color: var(--red);
  }

  @media (max-width: 768px) {
    .hero-inner {
      padding-top: 56px;
      padding-bottom: 56px;
    }

    .hero-name {
      font-size: clamp(32px, 8vw, 48px);
    }
  }
</style>