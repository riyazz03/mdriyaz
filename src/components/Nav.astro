---
---

<header class="nav">
  <div class="container nav-inner">
    <div class="nav-name">md<span>riyaz</span>.com</div>
    <div class="nav-avail">
      <span class="avail-dot" aria-hidden="true"></span>
      Available for work
    </div>
  </div>
</header>

<style>
  .nav {
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    z-index: 100;
  }

  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 24px;
    padding-bottom: 24px;
  }

  .nav-name {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--ink);
  }

  .nav-name span {
    color: var(--red);
  }

  .nav-avail {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .avail-dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--red);
    animation: blink 2s ease-in-out infinite;
  }
</style>